-- CORE FUNCTIONS

local function nukeGraphics()
    pcall(function() UserGameSettings.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1 end)
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 10000
    Lighting.FogStart = 9999
    Lighting.Brightness = 1
    Lighting.Ambient = Color3.fromRGB(128, 128, 128)
    Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
    for _, effect in ipairs(Lighting:GetChildren()) do
        if effect:IsA("PostEffect") or effect:IsA("BlurEffect")
            or effect:IsA("BloomEffect") or effect:IsA("ColorCorrectionEffect")
            or effect:IsA("SunRaysEffect") or effect:IsA("DepthOfFieldEffect") then
            effect:Destroy()
        end
    end
end

local function restoreGraphics()
    Lighting.GlobalShadows = true
    Lighting.FogEnd = 100000
    Lighting.FogStart = 0
    Lighting.Brightness = 2
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic end)
end

local function removeAccessories(character)
    for _, item in ipairs(character:GetChildren()) do
        if item:IsA("Accessory") or item:IsA("Hat")
            or item:IsA("Shirt") or item:IsA("Pants")
            or item:IsA("ShirtGraphic") or item:IsA("BodyColors") then
            item:Destroy()
        end
    end
    local bodyColors = Instance.new("BodyColors")
    bodyColors.HeadColor = BrickColor.new("Medium stone grey")
    bodyColors.TorsoColor = BrickColor.new("Medium stone grey")
    bodyColors.LeftArmColor = BrickColor.new("Medium stone grey")
    bodyColors.RightArmColor = BrickColor.new("Medium stone grey")
    bodyColors.LeftLegColor = BrickColor.new("Medium stone grey")
    bodyColors.RightLegColor = BrickColor.new("Medium stone grey")
    bodyColors.Parent = character
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Material = Enum.Material.SmoothPlastic
            part.CastShadow = false
        end
    end
end

local function nukeParticles()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ParticleEmitter") or obj:IsA("Beam")
            or obj:IsA("Trail") or obj:IsA("Fire")
            or obj:IsA("Smoke") or obj:IsA("Sparkles") then
            pcall(function() obj:Destroy() end)
        end
    end
end

local function muteSounds()
    SoundService.AmbientReverb = Enum.ReverbType.NoReverb
    for _, sound in ipairs(workspace:GetDescendants()) do
        if sound:IsA("Sound") then sound.Volume = 0 end
    end
end

local function restoreSounds()
    for _, sound in ipairs(workspace:GetDescendants()) do
        if sound:IsA("Sound") then sound.Volume = 0.5 end
    end
end

local particleConnection

local function applyAntiLag()
    enabled = true
    nukeGraphics()
    local character = LocalPlayer.Character
    if character then removeAccessories(character) end
    LocalPlayer.CharacterAdded:Connect(function(newChar)
        if enabled then task.wait(1) removeAccessories(newChar) end
    end)
    nukeParticles()
    muteSounds()
    particleConnection = workspace.DescendantAdded:Connect(function(obj)
        if enabled then
            if obj:IsA("ParticleEmitter") or obj:IsA("Trail")
                or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
                pcall(function() obj:Destroy() end)
            end
        end
    end)
end

local function removeAntiLag()
    enabled = false
    if particleConnection then particleConnection:Disconnect() end
    restoreGraphics()
    restoreSounds()
end

local frozenAnimators = {}
local ultraConnection

local function freezeBrainrotAnimations()
    local playerCharacters = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then playerCharacters[p.Character] = true end
    end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Animator") then
            local model = obj:FindFirstAncestorOfClass("Model")
            if model and not playerCharacters[model] then
                pcall(function()
                    for _, track in ipairs(obj:GetPlayingAnimationTracks()) do
                        track:Stop(0)
                        table.insert(frozenAnimators, track)
                    end
                end)
            end
        end
        if obj:IsA("AnimationController") then
            local model = obj:FindFirstAncestorOfClass("Model")
            if model and not playerCharacters[model] then
                pcall(function()
                    local animator = obj:FindFirstChildOfClass("Animator")
                    if animator then
                        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                            track:Stop(0)
                        end
                    end
                end)
            end
        end
    end
end

local function applyUltraAntiLag()
    ultraEnabled = true
    freezeBrainrotAnimations()
    ultraConnection = workspace.DescendantAdded:Connect(function(obj)
        if not ultraEnabled then return end
        task.wait(0.1)
        if obj:IsA("Animator") then
            local playerCharacters = {}
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character then playerCharacters[p.Character] = true end
            end
            local model = obj:FindFirstAncestorOfClass("Model")
            if model and not playerCharacters[model] then
                pcall(function()
                    for _, track in ipairs(obj:GetPlayingAnimationTracks()) do
                        track:Stop(0)
                    end
                end)
            end
        end
    end)
end

local function removeUltraAntiLag()
    ultraEnabled = false
    if ultraConnection then ultraConnection:Disconnect() end
    frozenAnimators = {}
end

local pingConnection

local function applyPingReducer()
    pingEnabled = true
    pcall(function() UserGameSettings.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1 end)
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
    Lighting.GlobalShadows = false
    pcall(function() Lighting.Technology = Enum.Technology.Compatibility end)
    for _, sky in ipairs(Lighting:GetChildren()) do
        if sky:IsA("Sky") or sky:IsA("Atmosphere") then sky:Destroy() end
    end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            pcall(function() obj.RenderFidelity = Enum.RenderFidelity.Automatic end)
            obj.CastShadow = false
        end
        if obj:IsA("Sound") then obj.Volume = 0 end
    end
    pingConnection = workspace.DescendantAdded:Connect(function(obj)
        if not pingEnabled then return end
        if obj:IsA("BasePart") then
            pcall(function() obj.RenderFidelity = Enum.RenderFidelity.Automatic end)
            obj.CastShadow = false
        end
        if obj:IsA("Sound") then obj.Volume = 0 end
    end)
end

local function removePingReducer()
    pingEnabled = false
    if pingConnection then pingConnection:Disconnect() end
    Lighting.GlobalShadows = true
    pcall(function() Lighting.Technology = Enum.Technology.Future end)
end

